# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: "openrouter" | "gcp"
LLM_PROVIDER=openrouter

# Model identifiers (format depends on the active provider)
# OpenRouter examples: deepseek/deepseek-v4-flash, anthropic/claude-sonnet-4-5
# GCP/Gemini examples: gemini-2.0-flash, gemini-2.5-pro
DEFAULT_MODEL=deepseek/deepseek-v4-flash
# OpenRouter examples: openai/text-embedding-3-small
# GCP/Gemini examples: text-embedding-004
EMBEDDING_MODEL=openai/text-embedding-3-small

# ── OpenRouter (LLM_PROVIDER=openrouter) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# Optional: pin to a specific upstream provider (e.g. "Together", "Fireworks")
# See https://openrouter.ai/docs/features/provider-routing
OPENROUTER_CHAT_PROVIDER=
OPENROUTER_EMBEDDING_PROVIDER=

# ── GCP / Google AI (LLM_PROVIDER=gcp) ────────────────────────────────────────
GCP_API_KEY=
# OpenAI-compatible base URL; default = Google AI (Gemini) endpoint
# For Vertex AI or other GCP-hosted endpoints, set this to the appropriate URL
GCP_ENDPOINT_URL=https://generativelanguage.googleapis.com/v1beta/openai

# MCP Server
MCP_API_KEY=your-secret-key
MCP_PORT=3000

# Vault Git Sync (private GitHub repo for knowledge persistence)
VAULT_GITHUB_URL=https://github.com/YOUR-USER/second-brain-vault.git
VAULT_GITHUB_PAT=github_pat_...

# Databases (set automatically by docker-compose service names)
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secretpassword
QDRANT_URL=http://qdrant:6333

# Vault filesystem path (inside the container)
VAULT_PATH=/vault

# Tracing (OpenTelemetry → Jaeger). Defaults to enabled in docker-compose;
# set OTEL_ENABLED=false to turn off. Jaeger UI: http://localhost:16686
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
