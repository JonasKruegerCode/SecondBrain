# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=sk-or-...
DEFAULT_MODEL=deepseek/deepseek-v4-flash
EMBEDDING_MODEL=openai/text-embedding-3-small
# Pin chat completions / embeddings to a specific upstream provider (no fallback),
# e.g. "Together" or "Fireworks" — see https://openrouter.ai/docs/features/provider-routing
# Leave empty to let OpenRouter pick automatically. Independent per model.
OPENROUTER_CHAT_PROVIDER=
OPENROUTER_EMBEDDING_PROVIDER=

# MCP Server
MCP_API_KEY=your-secret-key
MCP_PORT=3000

# Vault Git Sync (private GitHub repo for knowledge persistence)
VAULT_GITHUB_URL=https://github.com/YOUR-USER/second-brain-vault.git
VAULT_GITHUB_PAT=github_pat_...

# Databases (set automatically by docker-compose service names)
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secretpassword
QDRANT_URL=http://qdrant:6333

# Vault filesystem path (inside the container)
VAULT_PATH=/vault

# Tracing (OpenTelemetry → Jaeger). Defaults to enabled in docker-compose;
# set OTEL_ENABLED=false to turn off. Jaeger UI: http://localhost:16686
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
